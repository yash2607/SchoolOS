**/node_modules/
.git/
.vscode/
.claude/
.turbo/
**/dist/
**/build/
**/.expo/
*.docx

# Keep built workspace package outputs for Expo/EAS monorepo resolution
!packages/*/dist/
!packages/*/dist/**

# Exclude backend SOURCE files but keep package.json for pnpm workspace resolution
backend/services/*/src/
backend/services/*/test/
backend/services/*/.env*
backend/libs/*/src/
backend/libs/*/test/

# Exclude admin SOURCE files but keep package.json
apps/admin/src/
apps/admin/public/
apps/admin/.env*
apps/admin/dist/
