# App
APP_ENV=production
PORT=3001
ALLOWED_ORIGINS=https://vidyalay.online,https://www.vidyalay.online

# Database
# Railway injects DATABASE_URL automatically when you link a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/schoolos

# Redis
# Railway injects REDIS_URL automatically when you link a Redis service
REDIS_URL=redis://default:password@host:6379

# JWT
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_VALIDITY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60

# Preferred provider order: Fast2SMS WhatsApp -> Twilio WhatsApp -> console log fallback
FAST2SMS_API_KEY=REPLACE
FAST2SMS_WHATSAPP_PHONE_NUMBER_ID=REPLACE
FAST2SMS_WHATSAPP_API_VERSION=v24.0
FAST2SMS_WHATSAPP_TEMPLATE_NAME=REPLACE_WITH_APPROVED_TEMPLATE_NAME
FAST2SMS_WHATSAPP_TEMPLATE_LANGUAGE=en_US
# Set to true only if your approved template expects the OTP in a button parameter too.
FAST2SMS_WHATSAPP_TEMPLATE_HAS_BUTTON=false
FAST2SMS_WHATSAPP_TEMPLATE_BUTTON_SUBTYPE=url
FAST2SMS_WHATSAPP_TEMPLATE_BUTTON_INDEX=0

# Twilio fallback (optional)
TWILIO_ACCOUNT_SID=REPLACE
TWILIO_AUTH_TOKEN=REPLACE
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=REPLACE

# Google OAuth (optional)
GOOGLE_CLIENT_ID=REPLACE
GOOGLE_CLIENT_SECRET=REPLACE
GOOGLE_CALLBACK_URL=https://api.vidyalay.online/api/v1/auth/google/callback

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=REPLACE
MICROSOFT_CLIENT_SECRET=REPLACE
MICROSOFT_CALLBACK_URL=https://api.vidyalay.online/api/v1/auth/microsoft/callback

# SMTP (optional email delivery)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=REPLACE
SMTP_PASS=REPLACE
SMTP_FROM=REPLACE
